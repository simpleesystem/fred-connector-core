{
    "name": "simplee/fred-connector-core",
    "description": "Shared framework-agnostic PHP core for Talk to Fred WordPress connectors: HTTP transport, SLS-backed plugin update channel, OIDC server primitives, connection probe, and handoff/principal resolution.",
    "type": "library",
    "license": "proprietary",
    "authors": [
        {
            "name": "Talk to Fred",
            "email": "support@talktofred.ai"
        }
    ],
    "require": {
        "php": ">=8.1",
        "ext-json": "*",
        "guzzlehttp/guzzle": "^7.5",
        "lcobucci/jwt": "~5.3.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "php-stubs/wordpress-stubs": "^6.9",
        "phpstan/phpstan": "~2.1.50",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpunit/phpunit": "^12.0",
        "szepeviktor/phpstan-wordpress": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Simplee\\FredConnector\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Simplee\\FredConnector\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
